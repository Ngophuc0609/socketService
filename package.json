{
    "name": "apibechill-socket-server",
    "version": "1.0.0",
    "description": "Socket.io server for BeChill realtime communication",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "start:modular": "node src/index.js",
        "dev:modular": "nodemon src/index.js",
        "test": "node --test test/**/*.test.js",
        "test:preflight:staging": "node scripts/phase6/runPreflightCheck.js",
        "test:contract:staging": "node scripts/phase6/runContractTest.js",
        "test:soak:staging": "node scripts/phase6/runSoakTest.js",
        "test:phase6:gate": "node scripts/phase6/runPhase6Gate.js"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "ioredis": "^5.3.2",
        "socket.io": "^4.7.2"
    },
    "devDependencies": {
        "nodemon": "^3.0.2",
        "socket.io-client": "^4.8.3"
    }
}
