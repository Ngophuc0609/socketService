# Staging environment example for modular runtime
NODE_ENV=staging
PORT=8605
CORS_ORIGIN=*

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CHANNEL=bechill:events
REDIS_SOCKET_TTL_SECONDS=2592000
REDIS_LOCATION_TTL_SECONDS=300
REDIS_MAX_FALLBACK_TTL_SECONDS=604800

# Optional SQL database.
# If SQL is enabled but missing/unreachable, the service logs/Telegram-alerts
# and keeps running with Redis TTL capped to 7 days.
SQL_ENABLED=true
SQL_DRIVER=mysql
SQL_HOST=localhost
SQL_PORT=3306
SQL_DATABASE=bechill
SQL_USER=replace-with-sql-user
SQL_PASSWORD=replace-with-sql-password
# Alternative: SQL_URL=mysql://user:password@localhost:3306/bechill
SQL_CONNECTION_TIMEOUT_MS=5000

# Security policy
JWT_SECRET=replace-with-staging-jwt-secret
REQUIRE_JWT_SECRET_ON_STAGING=true

# Admin monitoring
ADMIN_MONITOR=true
ADMIN_JWT_SECRET=replace-with-staging-admin-secret

# Logging
DEBUG_SOCKET=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-5148733585
TELEGRAM_LEVEL=WARN

# Validation scripts
SERVICE_URL=http://localhost:8605
CONTRACT_DRIVER_USER_ID=driver-001
CONTRACT_CUSTOMER_USER_ID=customer-001
CONTRACT_DRIVER_BEARER=replace-with-driver-token
CONTRACT_CUSTOMER_BEARER=replace-with-customer-token
CONTRACT_TIMEOUT_MS=10000
CONTRACT_FIXTURE=document/fixtures/backend-bookingtrip-payloads.sample.json
SOAK_DURATION_SECONDS=300
SOAK_INTERVAL_MS=2000
